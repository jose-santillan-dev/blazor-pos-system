@page "/ventasFormulario/editar/0"
@page "/ventasFormulario/editar/{Id:int}"
@using Proyect.Data
@inject NavigationManager Nav
@inject Contexto ctx
@using Microsoft.EntityFrameworkCore
@inject IJSRuntime jsx


<PageTitle>Ventas</PageTitle>

<div class="container">
    <div class="row mt-3">

        <h4 class="mt-3 col">Verder producto</h4>

    <div class="text-end mb-3 mt-3 col">
        <button class="btn btn-primary" @onclick="VerVentas"> Ver Ventas</button>
    </div>

    </div>
    
    

    <EditForm Model="@oVentas" OnValidSubmit="Guardar">
        <DataAnnotationsValidator />
        <ValidationSummary />
        <div class="row mb-3 form-input-container">
            <div class="form-group mt-3 mb-3">
                <label>Productos disponible en inventario:</label>
                <select @bind="oVentas.InventarioId" @bind:after="ActualizarCantidadSeleccionada" class="form-control">
                    <option value="0">-- Seleccione un producto --</option>
                    @foreach (var inventario in oInventario)
                    {
                        <option value="@inventario.Id">@inventario.Name</option>
                    }
                    
                </select>
            </div>

            <div class="row mb-3">
                
                <div class="col">
                    <label for="cant" class="form-label">Cantidad | Disponible: @cantidadEnInventario </label>
                    <InputNumber id="cant" class="form-control" @bind-Value="oVentas.Cantidad"  />
                </div>
                <div class="col">
                    <label for="price" class="form-label">Sub Total</label>
                    <input type="number" id="price" class="form-control" step="0.01" readonly value="@(precioVenta = (precioBase * oVentas.Cantidad))" />
                </div>
            </div>

        </div>

       
        <div class="row mb-3">

            <div class="col">
                <label for="precioBase" class="form-label">Precio Base:</label>
                <Input id="precioBase"  class="form-control" readonly value="@precioBase" />
            </div>

            <div class="col">
                <label for="desc" class="form-label">Descripcion</label>
                <InputText id="desc" class="form-control" @bind-Value="@oVentas.Description" />
            </div>
        </div>


        <div class="text-center mb-3">
            <button type="submit" class="btn btn-success">Guardar</button>
        </div>
    </EditForm>
<br>

</div>

@code {

    [Parameter] public int Id { get; set; }

    private int? cantidadEnInventario = 0;

    //Esta variable se encarga de almacenar el total del precio venta para luego agregarlo a la base de datos
    //en el metodo guardar oVentas.PrecioVenta = precioVenta;
    private decimal precioVenta;

    Ventas oVentas = new Ventas();

    List<Inventory> oInventario = new();

    //Guardar

    protected async Task Guardar()
    {

        oVentas.precioVenta = precioVenta;

        if (await RevisarCantidad(oVentas.Id))
        {
            return;
        }

        oVentas.FechaVenta = DateTime.Now.Date;

        if (oVentas.Id > 0)
        {
            ctx.VentasDB.Update(oVentas);

        }
        else
        {
            ctx.VentasDB.Add(oVentas);

        }

        await ctx.SaveChangesAsync();
        StateHasChanged();
        VerVentas();


    }

    private void VerVentas(){
        Nav.NavigateTo("/ver_ventas");
    }

    protected override async Task OnInitializedAsync()
    {
        //se inicializa
        oVentas = new Ventas();

        //trae productos para el select
        oInventario = await ctx.InventoryDB.ToListAsync();

        //Si es edicion, llena todos los campos del formulario para poder editarlos

        if (Id != 0)
        {
            var data =  await ctx.VentasDB.FindAsync(Id);

            if (data != null)
            {
                oVentas = data;

                /*cuando la página carga (OnInitializedAsync) y el Id 
                * es distinto de cero, el select ya tendrá un valor, pero 
                 * @bind:after solo se dispara cuando el usuario cambia la 
                 * selección manualmente. Para que la cantidad aparezca 
                 * apenas cargue la página de edición, hay que
                 * llamar a BuscarCantidad al final de OnInitializedAsync:*/
    await BuscarCantidad(oVentas.InventarioId);
            }
        }

    }

        /*Estas dos funciones ActualizarCantidadSeleccionada y BuscarCantidad
      * se encargar una de traer el id desde el select hasta aca para primero
      * validar que no sea nulo y luego darselo a BuscarCantidad para que lo
      * relaciona que el producto en inventario y traiga su cantidad
      */

    

    private async Task ActualizarCantidadSeleccionada()
    {
        if (oVentas.InventarioId > 0)
        {
            await BuscarCantidad(oVentas.InventarioId);
            await Buscar_precio_base(oVentas.InventarioId);

        }
        else
        {
            cantidadEnInventario = 0;
        }
    }

    private async Task BuscarCantidad(int id)
    {
        var inventario = await ctx.InventoryDB
        .FirstOrDefaultAsync(i => i.Id == id);

        if (inventario != null)
        {
            cantidadEnInventario = inventario.Stock;
        }
        else
        {
            cantidadEnInventario = 0;
        }

    }

    //Esta funcion lo que hace es que busca el precioBase de el producto para luego
    //ser calcualdo en el formulario ventas cuando se selecciona una cantidad


    private decimal precioBase;

    private async Task Buscar_precio_base(int id)
    {
        var inventario = await ctx.InventoryDB
        .FirstOrDefaultAsync(i => i.Id == id);

        if (inventario != null)
        {
            precioBase = inventario.BasePrice;
        }
        else
        {
            precioBase = 0;
        }

    }

    

    private async Task<bool> RevisarCantidad(int id)
    {
        /*revisar si la cantidad que se quiere registrar como vendida es menor o
        igual a la cantidad disponible en el inventario*/

        //validar que no sea menor que cero

    if (oVentas.Cantidad < 0)
        {
            await jsx.InvokeVoidAsync("alert", $"Error: Cantidad no puede ser menor que sero -1");
            return true;
        }

        //Validar Edicion

        if(oVentas.Id > 0)
        {
            var productovendido = await ctx.VentasDB
            .AsNoTracking()
     .FirstOrDefaultAsync(x => x.Id == id);

            if (productovendido == null)
            {
                await jsx.InvokeVoidAsync("alert", "Error al buscar la venta");
                return true;
            }

            // SOLO validar si es edición
            if (oVentas.Cantidad != productovendido.Cantidad)
            {
                await jsx.InvokeVoidAsync("alert", "No puedes modificar la cantidad de una venta ya registrada");
                return true;
            }
            else
            {
                return false;
            }

        }

   
        var producto = await ctx.InventoryDB
         .FirstOrDefaultAsync(x => x.Id == oVentas.InventarioId);

        if (producto == null)
        {
            await jsx.InvokeVoidAsync("alert", $"Se ha producido un Error en la consulta de busqueda");
            return true;
        }

        if (producto.Stock < oVentas.Cantidad)
        {
            await jsx.InvokeVoidAsync("alert", $"Error: No hay suficiente inventario");
            return true;
        }

        //Descontar automáticamente el stock al vender
        producto.Stock -= oVentas.Cantidad;
        ctx.InventoryDB.Update(producto);
        return false;

    }



    
}

