@page "/inventarioForm"
@page "/inventarioForm/{Id:int}"
@inject NavigationManager Nav
@using Microsoft.EntityFrameworkCore
@inject IJSRuntime jsx
@inject Contexto ctx
@using Proyect.Data


<PageTitle>Inventario</PageTitle>

<div class="container">

    <h3 class="mt-3 pt-3 mb-3">Agregar nuevo</h3>

    <EditForm Model="@oInventario" OnValidSubmit="() => Guardar(oInventario.Id)">
        <DataAnnotationsValidator />
        <ValidationSummary />


        <div class="row mb-3">
            <div class="col">
                <label for="name" class="form-label">Producto</label>
                <InputText id="name" class="form-control" @bind-Value="@oInventario.Name" />
            </div>
            <div class="col">
                <label for="Stock" class="form-label">Stock</label>
                <InputNumber id="Stock" class="form-control" @bind-Value="@oInventario.Stock" />
            </div>
        </div>

        <div class="form-group mt-3 mb-3">
            <label for="estado">Estado:</label>
            <select @bind="oInventario.Estado" class="form-control">
                @foreach (var estado in Enum.GetValues(typeof(Inventory.Estados)))
                {
                    <option value="@estado">@estado</option>
                }
            </select>
        </div>

        <div class="row mb-3">
            <div class="col">
                <label for="Fechav" class="form-label">Fecha de Vencimiento</label>
                <InputDate id="Fechav" class="form-control" @bind-Value="@oInventario.FechaCaducidad" />
            </div>
            <div class="col">
                <label for="Fechav" class="form-label">Fecha de compra</label>
                <InputDate id="Fechav" class="form-control" @bind-Value="@oInventario.Fecha" />
            </div>

        </div>
        <div class="row mb-3">
            <div class="col">
                <label for="price" class="form-label">Precio</label>
                <InputNumber id="price" class="form-control" @bind-Value="@oInventario.BasePrice" />
            </div>
            <div class="col">
                <label for="desc" class="form-label">Descripcion</label>
                <InputText id="desc" class="form-control" @bind-Value="@oInventario.Description" />
            </div>
        </div>


        <div class="text-center mb-3">
            <button type="submit" class="btn btn-success">Guardar</button>
        </div>
    </EditForm>
    <br/>
</div>

@code {

    [Parameter]public int Id { get; set; }


    Inventory oInventario = new Inventory();


    protected async Task Guardar(int id)
    {
        var stock = await ctx.InventoryDB.Where(i => i.Id == id).FirstOrDefaultAsync();

        var existe = await ctx.InventoryDB
        .AnyAsync(i => i.Id != stock.Id && i.Stock == stock.Stock);

        if (existe)
        {
            await jsx.InvokeVoidAsync("alert", $"Error: Ya existe {stock.Stock} en inventario");
            return;
        }

        if(oInventario.Id > 0)
        {
            ctx.InventoryDB.Update(oInventario);
            await ctx.SaveChangesAsync();
        }
        else
        {
            ctx.InventoryDB.Add(oInventario);
            await ctx.SaveChangesAsync();
        }

        // Obtiene el registro actual del inventario según el Id.
        // Luego valida que no exista otro registro diferente con el mismo stock.
        // Si encuentra uno distinto con el mismo valor, muestra una alerta.

       

        StateHasChanged();
        Nav.NavigateTo("/ListaInventario");


    }

    protected override async Task OnInitializedAsync()
    {
        //Se inicializa

        oInventario = new Inventory();

        //Si es edicion, llena todos los campos del formulario para poder editarlos

        if (Id != 0)
        {

            var data = await ctx.InventoryDB.FindAsync(Id);

            if(data != null)
            {
                oInventario = data;
            }
        }

    }

}



